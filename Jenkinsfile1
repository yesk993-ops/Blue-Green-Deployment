pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
    }

    environment {
        IMAGE_NAME = "mydocker3692/bankapp"
        BLUE_TAG = "blue"
        GREEN_TAG = "green"
        KUBE_NAMESPACE = "webapps"
        MAVEN_HOME = tool 'maven'
        SCANNER_HOME = tool 'sonar-scanner'
        KUBECONFIG = "/var/lib/jenkins/.kube/config"
        TRIVY_CACHE_DIR = "/var/lib/jenkins/trivycache"
        DOCKER_CREDS = credentials('docker') 
    }

    stages {
        stage('Checkout Code') {
            steps {
                git branch: 'main',
                credentialsId: 'github',
                url: 'https://github.com/yesk993-ops/Blue-Green-Deployment.git'
            }
        }

        stage('Build Application') {
            steps {
                sh "${MAVEN_HOME}/bin/mvn clean package -DskipTests"
            }
        }

        stage('Security Analysis') {
            parallel {
                stage('Trivy Scan') {
                    steps { sh "trivy fs --cache-dir ${TRIVY_CACHE_DIR} --severity HIGH,CRITICAL --no-progress ." }
                }
                stage('SonarQube') {
                    steps {
                        withSonarQubeEnv('sonar') {
                            sh "${SCANNER_HOME}/bin/sonar-scanner -Dsonar.projectKey=bankapp -Dsonar.sources=."
                        }
                    }
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                sh """
                echo "${DOCKER_CREDS_PSW}" | docker login -u "${DOCKER_CREDS_USR}" --password-stdin
                
                docker build -t ${IMAGE_NAME}:${BLUE_TAG} .
                docker push ${IMAGE_NAME}:${BLUE_TAG}

                docker build -t ${IMAGE_NAME}:${GREEN_TAG} .
                docker push ${IMAGE_NAME}:${GREEN_TAG}
                """
            }
        }

        stage('Prepare K8s & MySQL') {
            steps {
                sh '''
                export KUBECONFIG=${KUBECONFIG}
                
                echo "1. Creating Namespace..."
                kubectl create namespace ${KUBE_NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -

                echo "2. Deploying MySQL (Requirement for both Blue/Green)..."
                # This applies your mysql-ds.yml which should contain Deployment + Service + PVC
                kubectl apply -f mysql-ds.yml -n ${KUBE_NAMESPACE}

                echo "3. Waiting for MySQL to be ready..."
                kubectl rollout status deployment/mysql -n ${KUBE_NAMESPACE} --timeout=120s

                echo "4. Applying App Service..."
                kubectl apply -f bankapp-service.yml -n ${KUBE_NAMESPACE}
                '''
            }
        }

        stage('Deploy BLUE (Active)') {
            steps {
                sh '''
                export KUBECONFIG=${KUBECONFIG}
                kubectl apply -f app-deployment-blue.yml -n ${KUBE_NAMESPACE}
                kubectl rollout status deployment/bankapp-blue -n ${KUBE_NAMESPACE}
                
                # Ensure traffic starts at Blue
                kubectl patch svc bankapp-service -n ${KUBE_NAMESPACE} \
                -p '{"spec":{"selector":{"app":"bankapp","version":"blue"}}}'
                '''
            }
        }

        stage('Deploy GREEN (Idle)') {
            steps {
                sh '''
                export KUBECONFIG=${KUBECONFIG}
                kubectl apply -f app-deployment-green.yml -n ${KUBE_NAMESPACE}
                kubectl rollout status deployment/bankapp-green -n ${KUBE_NAMESPACE}
                '''
            }
        }

        stage('Validation & Switch') {
            steps {
                echo "Blue is Live. Green is ready. Switching in 2 minute..."
                sleep(time: 2, unit: 'MINUTES')
                
                sh '''
                export KUBECONFIG=${KUBECONFIG}
                kubectl patch svc bankapp-service -n ${KUBE_NAMESPACE} \
                -p '{"spec":{"selector":{"app":"bankapp","version":"green"}}}'
                '''
            }
        }
    }
}
