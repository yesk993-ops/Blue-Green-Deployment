pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
    }

    environment {
        IMAGE_NAME = "mydocker3692/bankapp"
        TAG = "${BUILD_NUMBER}"
        KUBE_NAMESPACE = "webapps"
        MAVEN_HOME = tool 'maven'
        SCANNER_HOME = tool 'sonar-scanner'
        KUBECONFIG = "/var/lib/jenkins/.kube/config"
        TRIVY_CACHE_DIR = "/var/lib/jenkins/trivycache"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                credentialsId: 'github',
                url: 'https://github.com/yesk993-ops/Blue-Green-Deployment.git'
            }
        }

        stage('Build Application') {
            steps {
                sh "${MAVEN_HOME}/bin/mvn clean package -DskipTests"
            }
        }

        stage('Security & Code Analysis') {
            parallel {

                stage('Trivy Fast Scan') {
                    steps {
                        sh """
                        trivy fs \
                        --cache-dir ${TRIVY_CACHE_DIR} \
                        --skip-db-update \
                        --scanners vuln \
                        --severity HIGH,CRITICAL \
                        --no-progress .
                        """
                    }
                }

                stage('SonarQube Analysis') {
                    steps {
                        withSonarQubeEnv('sonar') {
                            sh """
                            ${SCANNER_HOME}/bin/sonar-scanner \
                            -Dsonar.projectKey=nodejsmysql \
                            -Dsonar.sources=.
                            """
                        }
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh """
                docker build \
                --cache-from ${IMAGE_NAME}:latest \
                -t ${IMAGE_NAME}:${TAG} .
                """
            }
        }

        stage('Trivy Image Scan (Fast)') {
            steps {
                sh """
                trivy image \
                --cache-dir ${TRIVY_CACHE_DIR} \
                --skip-db-update \
                --scanners vuln \
                --severity HIGH,CRITICAL \
                --no-progress \
                ${IMAGE_NAME}:${TAG}
                """
            }
        }

        stage('Prepare Kubernetes (Namespace + Service)') {
            steps {
                sh '''
                export KUBECONFIG=${KUBECONFIG}

                echo "Creating namespace if not exists..."
                kubectl create namespace ${KUBE_NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -

                echo "Creating service..."
                kubectl apply -f bankapp-service.yml -n ${KUBE_NAMESPACE}
                '''
            }
        }

        stage('Deploy BLUE Version (Active)') {
            steps {
                sh '''
                export KUBECONFIG=${KUBECONFIG}

                echo "Deploying BLUE version"

                kubectl apply -f app-deployment-blue.yml -n ${KUBE_NAMESPACE}

                kubectl rollout status deployment/bankapp-blue -n ${KUBE_NAMESPACE}

                echo "Routing traffic to BLUE"

                kubectl patch svc bankapp-service \
                -n ${KUBE_NAMESPACE} \
                -p '{"spec":{"selector":{"app":"bankapp","version":"blue"}}}'
                '''
            }
        }

        stage('Show Current Active Version') {
            steps {
                sh '''
                export KUBECONFIG=${KUBECONFIG}

                echo "Currently serving version:"

                kubectl get svc bankapp-service \
                -n ${KUBE_NAMESPACE} \
                -o jsonpath='{.spec.selector.version}'

                echo ""
                '''
            }
        }

        stage('Deploy GREEN Version (Idle)') {
            steps {
                sh '''
                export KUBECONFIG=${KUBECONFIG}

                echo "Deploying GREEN version (idle)"

                kubectl apply -f app-deployment-green.yml -n ${KUBE_NAMESPACE}

                kubectl rollout status deployment/bankapp-green -n ${KUBE_NAMESPACE}
                '''
            }
        }

        stage('Validation Window') {
            steps {
                echo "Waiting 2 minutes before switching traffic..."
                sleep(time: 2, unit: 'MINUTES')
            }
        }

        stage('Switch Traffic BLUE → GREEN') {
            steps {
                sh '''
                export KUBECONFIG=${KUBECONFIG}

                echo "Switching traffic to GREEN"

                kubectl patch svc bankapp-service \
                -n ${KUBE_NAMESPACE} \
                -p '{"spec":{"selector":{"app":"bankapp","version":"green"}}}'
                '''
            }
        }

        stage('Verify Traffic Switch') {
            steps {
                sh '''
                export KUBECONFIG=${KUBECONFIG}

                echo "Active version after switch:"

                kubectl get svc bankapp-service \
                -n ${KUBE_NAMESPACE} \
                -o jsonpath='{.spec.selector.version}'

                echo ""
                echo "Running Pods:"
                kubectl get pods -n ${KUBE_NAMESPACE} -o wide
                '''
            }
        }
    }
}
